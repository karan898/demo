// SCANLINE FILL ALGORITHM

#include <GL/glut.h>
#include <stdio.h>
#include <stdlib.h>
#include <math.h>

#define MAX 100
#define WIDTH 600
#define HEIGHT 600

int n;
int x[MAX], y[MAX];

float fillColor[3] = {1.0, 0.0, 0.0};
float boundaryColor[3] = {0.0, 0.0, 0.0};

void setPixel(int x, int y, float color[3]) {
glColor3fv(color);
glBegin(GL_POINTS);
glVertex2i(x, y);
glEnd();
glFlush();
}

void scanLineFill() {
int i, j, k;
float slope[MAX];

for(i = 0; i < n; i++) {
if(y[(i+1)%n] - y[i] != 0)
slope[i] = (float)(x[(i+1)%n] - x[i]) /
(y[(i+1)%n] - y[i]);
else
slope[i] = 0;
}

for(int scanY = 0; scanY < HEIGHT; scanY++) {
int intersections[MAX];
int count = 0;

for(i = 0; i < n; i++) {
if((y[i] <= scanY && y[(i+1)%n] > scanY) ||
(y[(i+1)%n] <= scanY && y[i] > scanY)) {

intersections[count++] =
x[i] + slope[i] * (scanY - y[i]);
}
}

for(i = 0; i < count-1; i++)
for(j = i+1; j < count; j++)
if(intersections[i] > intersections[j]) {
int temp = intersections[i];
intersections[i] = intersections[j];
intersections[j] = temp;
}

for(k = 0; k < count; k += 2) {
for(int xFill = intersections[k];
xFill <= intersections[k+1]; xFill++) {

setPixel(xFill, scanY, fillColor);
}
}
}
}

void display() {
glClear(GL_COLOR_BUFFER_BIT);

glColor3fv(boundaryColor);
glBegin(GL_LINE_LOOP);
for(int i = 0; i < n; i++)
glVertex2i(x[i], y[i]);
glEnd();

scanLineFill();

glFlush();
}

void init() {
glClearColor(1.0, 1.0, 1.0, 1.0);
glColor3f(0.0, 0.0, 0.0);
gluOrtho2D(0, WIDTH, 0, HEIGHT);
}

int main(int argc, char** argv) {

printf("Enter number of vertices: ");
scanf("%d", &n);

printf("Enter coordinates (x y):\n");
for(int i = 0; i < n; i++)
scanf("%d %d", &x[i], &y[i]);

glutInit(&argc, argv);
glutInitDisplayMode(GLUT_SINGLE | GLUT_RGB);
glutInitWindowSize(WIDTH, HEIGHT);
glutCreateWindow("Scan-Line Fill Algorithm");

init();
glutDisplayFunc(display);

glutMainLoop();
return 0;
}