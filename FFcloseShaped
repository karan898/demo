#include <GL/glut.h>
#include <stdio.h>
#include <stdlib.h>
#define MAX 100
#define WIDTH 600
#define HEIGHT 600
int n;
int x[MAX], y[MAX];
// Fill color (Red)
unsigned char fillColor[3] = {255, 0, 0};
// Background color (White)
unsigned char bgColor[3] = {255, 255, 255};
// -------------------- Set Pixel --------------------
void setPixel(int x, int y)
{
glColor3ub(fillColor[0], fillColor[1], fillColor[2]);
glBegin(GL_POINTS);
glVertex2i(x, y);
glEnd();
glFlush();
}
// -------------------- Get Pixel --------------------
void getPixel(int x, int y, unsigned char color[3])
{
glReadPixels(x, y, 1, 1, GL_RGB, GL_UNSIGNED_BYTE, color);
}
// -------------------- Flood Fill (4-connected) --------------------
void floodFill(int x, int y)
{
unsigned char currentColor[3];
getPixel(x, y, currentColor);
// If current pixel is background color
if(currentColor[0] == bgColor[0] &&
currentColor[1] == bgColor[1] &&
currentColor[2] == bgColor[2])
{
setPixel(x, y);
floodFill(x+1, y);
floodFill(x-1, y);
floodFill(x, y+1);
floodFill(x, y-1);
}
}
// -------------------- Display --------------------
void display()
{
glClear(GL_COLOR_BUFFER_BIT);
// Draw polygon boundary (Black)
glColor3f(0.0, 0.0, 0.0);
glBegin(GL_LINE_LOOP);
for(int i = 0; i < n; i++)
glVertex2i(x[i], y[i]);
glEnd();
glFlush();
}
// -------------------- Mouse --------------------
void mouse(int btn, int state, int mx, int my)
{
if(state == GLUT_DOWN && btn == GLUT_LEFT_BUTTON)
{
int xClick = mx;
int yClick = HEIGHT - my - 1; // Convert coordinates
floodFill(xClick, yClick);
}
}
// -------------------- Initialization --------------------
void init()
{
glClearColor(1.0, 1.0, 1.0, 1.0); // White background
gluOrtho2D(0, WIDTH, 0, HEIGHT);
}
// -------------------- Main --------------------
int main(int argc, char** argv)
{
printf("Enter number of vertices: ");
scanf("%d", &n);
printf("Enter coordinates (x y):\n");
for(int i = 0; i < n; i++)
scanf("%d %d", &x[i], &y[i]);
glutInit(&argc, argv);
glutInitDisplayMode(GLUT_SINGLE | GLUT_RGB);
glutInitWindowSize(WIDTH, HEIGHT);
glutCreateWindow("Flood Fill Algorithm");
init();
glutDisplayFunc(display);
glutMouseFunc(mouse);
glutMainLoop();
return 0;
}
